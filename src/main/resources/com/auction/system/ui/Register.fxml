<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.system.ui.Register">
   <children>
      <VBox alignment="CENTER" layoutX="125.0" layoutY="20.0" prefWidth="350.0" spacing="15.0" style="-fx-background-color: #ffffff; -fx-border-color: #cccccc; -fx-border-radius: 10; -fx-background-radius: 10;">
         <children>
            <Label text="ĐĂNG KÝ TÀI KHOẢN" textFill="#333333">
               <font>
                  <Font name="System Bold" size="22.0" />
               </font>
            </Label>

            <VBox spacing="5.0">
               <children>
                  <Label text="Tên đăng nhập:" />
                  <TextField fx:id="txtUsername" prefHeight="35.0" promptText="Nhập tên đăng nhập..." />
               </children>
            </VBox>

            <VBox spacing="5.0">
               <children>
                  <Label text="Mật khẩu:" />
                  <PasswordField fx:id="txtPassword" prefHeight="35.0" promptText="Nhập mật khẩu..." />
               </children>
            </VBox>

            <VBox spacing="5.0">
               <children>
                  <Label text="Nhập lại mật khẩu:" />
                  <PasswordField fx:id="txtConfirmPassword" prefHeight="35.0" promptText="Xác nhận lại mật khẩu..." />
               </children>
            </VBox>

            <Button mnemonicParsing="false" onAction="#handleRegister" prefHeight="40.0" prefWidth="350.0" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5;" text="TẠO TÀI KHOẢN" />

            <Button mnemonicParsing="false" onAction="#goLogin" style="-fx-background-color: transparent; -fx-text-fill: #6c757d; -fx-underline: true;" text="Đã có tài khoản? Quay lại Đăng nhập" />
         </children>
         <padding>
            <Insets bottom="25.0" left="30.0" right="30.0" top="25.0" />
         </padding>
      </VBox>
   </children>
</AnchorPane>