<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="580.0" prefWidth="640.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.system.ui.Register">
   <children>
      <VBox alignment="CENTER" layoutX="145.0" layoutY="25.0" prefWidth="350.0" spacing="12.0" style="-fx-background-color: #ffffff; -fx-border-color: #cccccc; -fx-border-radius: 10; -fx-background-radius: 10;">
         <children>
            <Label text="DANG KY TAI KHOAN" textFill="#333333">
               <font>
                  <Font name="System Bold" size="22.0" />
               </font>
            </Label>

            <VBox spacing="5.0">
               <children>
                  <Label text="Ho ten:" />
                  <TextField fx:id="txtFullName" prefHeight="35.0" promptText="Nhap ho ten..." />
               </children>
            </VBox>

            <VBox spacing="5.0">
               <children>
                  <Label text="Ten dang nhap:" />
                  <TextField fx:id="txtUsername" prefHeight="35.0" promptText="Nhap ten dang nhap..." />
               </children>
            </VBox>

            <VBox spacing="5.0">
               <children>
                  <Label text="Email:" />
                  <TextField fx:id="txtEmail" prefHeight="35.0" promptText="Nhap email..." />
               </children>
            </VBox>

            <VBox spacing="5.0">
               <children>
                  <Label text="Mat khau:" />
                  <PasswordField fx:id="txtPassword" prefHeight="35.0" promptText="Nhap mat khau..." />
               </children>
            </VBox>

            <VBox spacing="5.0">
               <children>
                  <Label text="Nhap lai mat khau:" />
                  <PasswordField fx:id="txtConfirmPassword" prefHeight="35.0" promptText="Xac nhan lai mat khau..." />
               </children>
            </VBox>

            <VBox spacing="5.0">
               <children>
                  <Label text="Vai tro:" />
                  <ComboBox fx:id="cbRole" prefHeight="35.0" prefWidth="350.0" />
               </children>
            </VBox>

            <Button mnemonicParsing="false" onAction="#handleRegister" prefHeight="40.0" prefWidth="350.0" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5;" text="TAO TAI KHOAN" />

            <Button mnemonicParsing="false" onAction="#goLogin" style="-fx-background-color: transparent; -fx-text-fill: #6c757d; -fx-underline: true;" text="Da co tai khoan? Quay lai dang nhap" />
         </children>
         <padding>
            <Insets bottom="25.0" left="30.0" right="30.0" top="25.0" />
         </padding>
      </VBox>
   </children>
</AnchorPane>
