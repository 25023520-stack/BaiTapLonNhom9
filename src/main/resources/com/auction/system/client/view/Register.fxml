<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<AnchorPane prefHeight="580.0" prefWidth="900.0" styleClass="main-background" stylesheets="@Styles.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.system.client.controller.RegisterController">
    <children>

        <!-- Left brand panel -->
        <VBox alignment="CENTER" prefWidth="220.0" styleClass="brand-panel"
              AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0">
            <children>
                <ImageView fitHeight="108.0" fitWidth="108.0" preserveRatio="true" styleClass="brand-logo">
                    <image>
                        <Image url="@assets/dai-hoc-cong-nghe-logo.png" />
                    </image>
                </ImageView>
                <Label styleClass="brand-title" text="AuctionHub" />
                <Label styleClass="brand-subtitle" text="Tạo tài khoản mới&#10;và bắt đầu ngay" />
            </children>
        </VBox>

        <!-- Right form panel -->
        <VBox alignment="CENTER" prefWidth="680.0" styleClass="form-panel"
              AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0" AnchorPane.rightAnchor="0.0">
            <children>

                <VBox styleClass="login-card" spacing="0">
                    <children>

                        <!-- Header -->
                        <VBox styleClass="card-header" spacing="4">
                            <children>
                                <Label styleClass="login-title" text="Đăng Ký" />
                                <Label styleClass="login-subtitle" text="Điền thông tin để tạo tài khoản" />
                            </children>
                        </VBox>

                        <Rectangle styleClass="card-divider" height="1.0" width="420.0" />

                        <!-- Form body -->
                        <VBox styleClass="card-body" spacing="12">
                            <children>

                                <!-- Full name -->
                                <VBox spacing="5">
                                    <children>
                                        <Label styleClass="input-label" text="Họ và tên" />
                                        <HBox styleClass="input-wrapper" alignment="CENTER_LEFT" spacing="8">
                                            <children>
                                                <Label styleClass="input-icon" text="👤" />
                                                <TextField fx:id="txtFullName" onAction="#handleRegister"
                                                           promptText="Nhập họ và tên..."
                                                           styleClass="input-field" HBox.hgrow="ALWAYS" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <!-- Username -->
                                <VBox spacing="5">
                                    <children>
                                        <Label styleClass="input-label" text="Tên đăng nhập" />
                                        <HBox styleClass="input-wrapper" alignment="CENTER_LEFT" spacing="8">
                                            <children>
                                                <Label styleClass="input-icon" text="\@" />
                                                <TextField fx:id="txtUsername" onAction="#handleRegister"
                                                           promptText="Nhập tài khoản..."
                                                           styleClass="input-field" HBox.hgrow="ALWAYS" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <!-- Password + Confirm row -->
                                <GridPane hgap="12">
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="ALWAYS" percentWidth="50" />
                                        <ColumnConstraints hgrow="ALWAYS" percentWidth="50" />
                                    </columnConstraints>
                                    <rowConstraints>
                                        <RowConstraints />
                                    </rowConstraints>
                                    <children>
                                        <VBox spacing="5" GridPane.columnIndex="0">
                                            <children>
                                                <Label styleClass="input-label" text="Mật khẩu" />
                                                <HBox styleClass="input-wrapper" alignment="CENTER_LEFT" spacing="8">
                                                    <children>
                                                        <Label styleClass="input-icon" text="🔒" />
                                                        <PasswordField fx:id="txtPassword" onAction="#handleRegister"
                                                                       promptText="Nhập mật khẩu..."
                                                                       styleClass="input-field" HBox.hgrow="ALWAYS" />
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>
                                        <VBox spacing="5" GridPane.columnIndex="1">
                                            <children>
                                                <Label styleClass="input-label" text="Xác nhận mật khẩu" />
                                                <HBox styleClass="input-wrapper" alignment="CENTER_LEFT" spacing="8">
                                                    <children>
                                                        <Label styleClass="input-icon" text="🔒" />
                                                        <PasswordField fx:id="txtConfirmPassword" onAction="#handleRegister"
                                                                       promptText="Nhập lại mật khẩu"
                                                                       styleClass="input-field" HBox.hgrow="ALWAYS" />
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </GridPane>

                                <!-- Role -->
                                <VBox spacing="5">
                                    <children>
                                        <Label styleClass="input-label" text="Vai trò" />
                                        <HBox styleClass="input-wrapper" alignment="CENTER_LEFT" spacing="8">
                                            <children>
                                                <Label styleClass="input-icon" text="👥" />
                                                <ComboBox fx:id="cbRole" maxWidth="Infinity"
                                                          promptText="Chọn vai trò..."
                                                          styleClass="combo-field" HBox.hgrow="ALWAYS" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <!-- Register button -->
                                <Button fx:id="btnRegister" defaultButton="true" maxWidth="Infinity"
                                        mnemonicParsing="false" onAction="#handleRegister"
                                        styleClass="primary-button" text="Đăng Ký" />

                                <!-- Back to login -->
                                <HBox alignment="CENTER" spacing="6">
                                    <children>
                                        <Label styleClass="hint-text" text="Đã có tài khoản?" />
                                        <Button mnemonicParsing="false" onAction="#goLogin"
                                                styleClass="link-button" text="Đăng nhập ngay" />
                                    </children>
                                </HBox>

                            </children>
                        </VBox>

                    </children>
                </VBox>

            </children>
        </VBox>

    </children>
</AnchorPane>
