<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="470.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.system.client.controller.RegisterController">
    <children>
        <VBox alignment="CENTER" layoutX="135.0" layoutY="25.0" prefHeight="420.0" prefWidth="330.0" spacing="16.0" style="-fx-background-color: #ffffff; -fx-border-color: #cccccc; -fx-border-radius: 10; -fx-background-radius: 10;">
            <children>
                <Label text="ĐĂNG KÝ" textFill="#333333">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                </Label>
                <VBox spacing="5.0">
                    <children>
                        <Label text="Họ và tên:" />
                        <TextField fx:id="txtFullName" prefHeight="35.0" promptText="Nhập họ và tên" />
                    </children>
                </VBox>
                <VBox spacing="5.0">
                    <children>
                        <Label text="Tên đăng nhập:" />
                        <TextField fx:id="txtUsername" prefHeight="35.0" promptText="Nhập tài khoản..." />
                    </children>
                </VBox>
                <VBox spacing="5.0">
                    <children>
                        <Label text="Mật khẩu:" />
                        <PasswordField fx:id="txtPassword" prefHeight="35.0" promptText="Nhập mật khẩu..." />
                    </children>
                </VBox>
                <VBox spacing="5.0">
                    <children>
                        <Label text="Xác nhận mật khẩu:" />
                        <PasswordField fx:id="txtConfirmPassword" prefHeight="35.0" promptText="Nhập lại mật khẩu..." />
                    </children>
                </VBox>
                <VBox spacing="5.0">
                    <children>
                        <Label text="Vai trò:" />
                        <ComboBox fx:id="cbRole" prefHeight="35.0" prefWidth="270.0" />
                    </children>
                </VBox>
                <Button mnemonicParsing="false" onAction="#handleRegister" prefHeight="40.0" prefWidth="300.0" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5;" text="ĐĂNG KÝ" />
                <Button mnemonicParsing="false" onAction="#goLogin" style="-fx-background-color: transparent; -fx-text-fill: #007bff; -fx-underline: true;" text="Đã có tài khoản? Đăng nhập" />
            </children>
            <padding>
                <Insets bottom="24.0" left="30.0" right="30.0" top="24.0" />
            </padding>
        </VBox>
    </children>
</AnchorPane>
