<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.shape.Rectangle?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" styleClass="main-background" stylesheets="@Styles.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.system.client.controller.LoginController">
    <children>

        <!-- Left panel: branding/illustration side -->
        <VBox alignment="CENTER" prefWidth="450.0" styleClass="brand-panel"
              AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0">
            <children>
                <ImageView fitHeight="120.0" fitWidth="120.0" preserveRatio="true" styleClass="brand-logo">
                    <image>
                        <Image url="@assets/dai-hoc-cong-nghe-logo.png" />
                    </image>
                </ImageView>
                <Label styleClass="brand-title" text="AuctionHub" />
                <Label styleClass="brand-subtitle" text="Hệ Thống Đấu Gíá&#10;UET" />
            </children>
        </VBox>

        <!-- Right panel: login form -->
        <VBox alignment="CENTER" prefWidth="450.0" styleClass="form-panel"
              AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0" AnchorPane.rightAnchor="0.0">
            <children>

                <!-- Card container -->
                <VBox styleClass="login-card" spacing="0">
                    <children>

                        <!-- Header -->
                        <VBox styleClass="card-header" spacing="6">
                            <children>
                                <Label styleClass="login-title" text="Đăng Nhập" />
                                <Label styleClass="login-subtitle" text="Chào mừng bạn quay trở lại" />
                            </children>
                        </VBox>

                        <!-- Divider -->
                        <Rectangle styleClass="card-divider" height="1.0" width="360.0" />

                        <!-- Form body -->
                        <VBox styleClass="card-body" spacing="20">
                            <children>

                                <!-- Username field -->
                                <VBox spacing="8">
                                    <children>
                                        <Label styleClass="input-label" text="Tên đăng nhập" />
                                        <HBox styleClass="input-wrapper" alignment="CENTER_LEFT" spacing="10">
                                            <children>
                                                <Label styleClass="input-icon" text="👤" />
                                                <TextField fx:id="txtUsername" onAction="#handleLogin"
                                                           promptText="Nhập tài khoản"
                                                           styleClass="input-field" HBox.hgrow="ALWAYS" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <!-- Password field -->
                                <VBox spacing="8">
                                    <children>
                                        <Label styleClass="input-label" text="Mật khẩu" />
                                        <HBox styleClass="input-wrapper" alignment="CENTER_LEFT" spacing="10">
                                            <children>
                                                <Label styleClass="input-icon" text="🔒" />
                                                <PasswordField fx:id="txtPassword" onAction="#handleLogin"
                                                               promptText="Nhập mật khẩu"
                                                               styleClass="input-field" HBox.hgrow="ALWAYS" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <!-- Login button -->
                                <Button fx:id="btnLogin" defaultButton="true" maxWidth="Infinity"
                                        mnemonicParsing="false" onAction="#handleLogin"
                                        styleClass="primary-button" text="Đăng Nhập" />

                                <!-- Register link -->
                                <HBox alignment="CENTER" spacing="4">
                                    <children>
                                        <Label styleClass="hint-text" text="Chưa có tài khoản?" />
                                        <Button mnemonicParsing="false" onAction="#goToRegister"
                                                styleClass="link-button" text="Đăng ký ngay" />
                                    </children>
                                </HBox>

                            </children>
                        </VBox>

                    </children>
                </VBox>

            </children>
        </VBox>

    </children>
</AnchorPane>
