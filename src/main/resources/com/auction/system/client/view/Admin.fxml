<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane minHeight="600.0" minWidth="900.0" prefHeight="720.0" prefWidth="1120.0" styleClass="main-background" stylesheets="@Styles.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.system.client.controller.AdminController">

    <top>
        <VBox spacing="0.0" styleClass="admin-header">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="18.0" styleClass="admin-header-content">
                    <children>
                        <StackPane minHeight="64.0" minWidth="64.0" prefHeight="64.0" prefWidth="64.0" styleClass="bidder-logo-frame">
                            <children>
                                <ImageView fitHeight="52.0" fitWidth="52.0" preserveRatio="true" smooth="true">
                                    <image>
                                        <Image url="@assets/logouetnentrang.jpg" />
                                    </image>
                                </ImageView>
                            </children>
                        </StackPane>
                        <VBox alignment="CENTER_LEFT" spacing="2.0">
                            <children>
                                <Label styleClass="admin-header-title" text="AuctionHub Admin" />
                        <Label styleClass="admin-header-subtitle" text="Quản trị người dùng, sản phẩm và các hàng chờ duyệt" />
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER" spacing="8.0" styleClass="admin-status-pill">
                            <children>
                                <Circle fill="#37F2C4" radius="4.5" />
                                <Label styleClass="admin-status-text" text="Admin Workspace" />
                            </children>
                        </HBox>
                        <Button mnemonicParsing="false" onAction="#handleLogout" styleClass="logout-button" text="Đăng xuất" />
                    </children>
                </HBox>
                <Rectangle fill="#FFFFFF" height="1.0" opacity="0.20" width="1120.0" />
            </children>
        </VBox>
    </top>

    <left>
        <VBox prefWidth="220.0" spacing="12.0" styleClass="admin-sidebar">
            <children>
                <VBox spacing="5.0">
                    <children>
                        <Label styleClass="seller-section-title" text="Hàng chờ admin" />
                        <Label styleClass="seller-page-subtitle"
                               text="Theo dõi các seller mới và những phiên đang chờ phê duyệt."
                               wrapText="true" />
                    </children>
                </VBox>

                <Button fx:id="btnShowUsers" maxWidth="1.7976931348623157E308"
                        mnemonicParsing="false" onAction="#showUserManagement"
                        styleClass="queue-tab-button">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <children>
                                <Label styleClass="admin-subsection-title" text="Người dùng"
                                       mouseTransparent="true" />
                                <Region HBox.hgrow="ALWAYS" mouseTransparent="true" />
                                <Label fx:id="userCountLabel" styleClass="admin-count-badge"
                                       text="0" mouseTransparent="true" />
                            </children>
                        </HBox>
                    </graphic>
                </Button>

                <Button fx:id="btnShowItems" maxWidth="1.7976931348623157E308"
                        mnemonicParsing="false" onAction="#showItemManagement"
                        styleClass="queue-tab-button">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <children>
                                <Label styleClass="admin-subsection-title" text="Sản phẩm"
                                       mouseTransparent="true" />
                                <Region HBox.hgrow="ALWAYS" mouseTransparent="true" />
                                <Label fx:id="itemCountLabel" styleClass="admin-count-badge"
                                       text="0" mouseTransparent="true" />
                            </children>
                        </HBox>
                    </graphic>
                </Button>

                <!-- Nút 1: Seller chờ duyệt -->
                <Button fx:id="btnShowSellers" maxWidth="1.7976931348623157E308"
                        mnemonicParsing="false" onAction="#showSellerQueue"
                        styleClass="queue-tab-button">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <children>
                                <Label styleClass="admin-subsection-title" text="Seller chờ duyệt"
                                       mouseTransparent="true" />
                                <Region HBox.hgrow="ALWAYS" mouseTransparent="true" />
                                <Label fx:id="sellerCountLabel" styleClass="admin-count-badge"
                                       text="0" mouseTransparent="true" />
                            </children>
                        </HBox>
                    </graphic>
                </Button>

                <!-- Nút 2: Phiên chờ duyệt -->
                <Button fx:id="btnShowAuctions" maxWidth="1.7976931348623157E308"
                        mnemonicParsing="false" onAction="#showAuctionQueue"
                        styleClass="queue-tab-button">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <children>
                                <Label styleClass="admin-subsection-title" text="Phiên chờ duyệt"
                                       mouseTransparent="true" />
                                <Region HBox.hgrow="ALWAYS" mouseTransparent="true" />
                                <Label fx:id="auctionCountLabel" styleClass="admin-count-badge"
                                       text="0" mouseTransparent="true" />
                            </children>
                        </HBox>
                    </graphic>
                </Button>

                <!-- Nút 3: Nạp tiền -->
                <Button fx:id="btnShowDeposits" maxWidth="1.7976931348623157E308"
                        mnemonicParsing="false" onAction="#showDepositQueue"
                        styleClass="queue-tab-button">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <children>
                                <Label styleClass="admin-subsection-title" text="Nạp tiền cho bidder"
                                       mouseTransparent="true" />
                                <Region HBox.hgrow="ALWAYS" mouseTransparent="true" />
                                <Label fx:id="depositCountLabel" styleClass="admin-count-badge"
                                       text="0" mouseTransparent="true" />
                            </children>
                        </HBox>
                    </graphic>
                </Button>

                <Region VBox.vgrow="ALWAYS" />

                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                        onAction="#refreshDashboard" styleClass="secondary-button"
                        text="Làm mới dashboard" />
            </children>
        </VBox>
    </left>

    <center>
        <HBox spacing="6.0" styleClass="admin-center">
            <children>

                <!-- CỘT TRÁI: Danh sách chờ duyệt (ẩn/hiện theo tab) -->
                <VBox prefWidth="220.0" spacing="0.0" styleClass="admin-list-panel">
                    <children>
                        <VBox fx:id="userListContainer" spacing="8.0"
                              styleClass="admin-card"
                              VBox.vgrow="ALWAYS" visible="false" managed="false">
                            <children>
                                <Label styleClass="admin-list-header" text="Tất cả người dùng" />
                                <HBox alignment="CENTER_LEFT" spacing="8.0" styleClass="input-wrapper">
                                    <children>
                                        <Label styleClass="input-icon" text="S" />
                                        <TextField fx:id="adminUserSearchField" promptText="Tìm user" styleClass="input-field" HBox.hgrow="ALWAYS" />
                                    </children>
                                </HBox>
                                <ComboBox fx:id="adminRoleFilterComboBox" maxWidth="1.7976931348623157E308" styleClass="combo-field" />
                                <ListView fx:id="allUserListView" styleClass="auction-list-view"
                                          VBox.vgrow="ALWAYS" />
                            </children>
                        </VBox>

                        <VBox fx:id="itemListContainer" spacing="8.0"
                              styleClass="admin-card"
                              VBox.vgrow="ALWAYS" visible="false" managed="false">
                            <children>
                                <Label styleClass="admin-list-header" text="Tất cả sản phẩm" />
                                <HBox alignment="CENTER_LEFT" spacing="8.0" styleClass="input-wrapper">
                                    <children>
                                        <Label styleClass="input-icon" text="S" />
                                        <TextField fx:id="adminItemSearchField" promptText="Tìm sản phẩm" styleClass="input-field" HBox.hgrow="ALWAYS" />
                                    </children>
                                </HBox>
                                <ComboBox fx:id="adminItemStatusFilterComboBox" maxWidth="1.7976931348623157E308" styleClass="combo-field" />
                                <ListView fx:id="allItemListView" styleClass="auction-list-view"
                                          VBox.vgrow="ALWAYS" />
                            </children>
                        </VBox>

                        <!-- ListView Seller -->
                        <VBox fx:id="sellerListContainer" spacing="8.0"
                              styleClass="admin-card"
                              VBox.vgrow="ALWAYS" visible="false" managed="false">
                            <children>
                                <Label styleClass="admin-list-header" text="Danh sách seller chờ duyệt" />
                                <ListView fx:id="sellerListView" styleClass="auction-list-view"
                                          VBox.vgrow="ALWAYS" />
                            </children>
                        </VBox>
                        <!-- ListView Phiên -->
                        <VBox fx:id="auctionListContainer" spacing="8.0"
                              styleClass="admin-card"
                              VBox.vgrow="ALWAYS" visible="false" managed="false">
                            <children>
                                <Label styleClass="admin-list-header" text="Danh sách phiên chờ duyệt" />
                                <ListView fx:id="auctionListView" styleClass="auction-list-view"
                                          VBox.vgrow="ALWAYS" />
                            </children>
                        </VBox>
                        <!-- ListView Nạp tiền -->
                        <VBox fx:id="depositListContainer" spacing="8.0"
                              styleClass="admin-card"
                              VBox.vgrow="ALWAYS" visible="false" managed="false">
                            <children>
                                <Label styleClass="admin-list-header" text="Yêu cầu nạp tiền chờ duyệt" />
                                <ListView fx:id="depositListView" styleClass="auction-list-view"
                                          VBox.vgrow="ALWAYS" />
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <!-- CỘT PHẢI: Chi tiết (3 card, chỉ 1 hiện tại một thời điểm) -->
                <StackPane HBox.hgrow="ALWAYS">
                    <children>

                        <!-- CARD 1: Chi tiết Seller -->
                        <VBox fx:id="userManagementDetailPane" spacing="16.0" styleClass="admin-card"
                              visible="false" managed="false">
                            <children>
                                <VBox spacing="4.0">
                                    <children>
                                        <Label styleClass="seller-page-title" text="Quản lý người dùng" />
                                        <Label styleClass="seller-page-subtitle" text="Xem thông tin tài khoản và xóa khi không còn ràng buộc dữ liệu." wrapText="true" />
                                    </children>
                                </VBox>
                                <HBox spacing="18.0">
                                    <children>
                                        <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="input-label" text="Họ tên" />
                                                <Label fx:id="managedUserNameValue" styleClass="auction-info-value" text="-" wrapText="true" />
                                                <Label styleClass="input-label" text="Username" />
                                                <Label fx:id="managedUserUsernameValue" styleClass="auction-info-value" text="-" wrapText="true" />
                                                <Label styleClass="input-label" text="Email" />
                                                <Label fx:id="managedUserEmailValue" styleClass="auction-info-value" text="-" wrapText="true" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="input-label" text="Vai trò" />
                                                <Label fx:id="managedUserRoleValue" styleClass="seller-inline-status" text="-" wrapText="true" />
                                                <Label styleClass="input-label" text="Trạng thái" />
                                                <Label fx:id="managedUserStatusValue" styleClass="seller-inline-status" text="-" wrapText="true" />
                                                <Label styleClass="input-label" text="Số dư" />
                                                <Label fx:id="managedUserBalanceValue" styleClass="bidder-price-value" text="-" wrapText="true" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                                <Region VBox.vgrow="ALWAYS" />
                                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                                    <children>
                                        <Button fx:id="deleteUserButton" mnemonicParsing="false"
                                                onAction="#deleteSelectedUser" styleClass="danger-button"
                                                text="Xóa người dùng" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox fx:id="itemManagementDetailPane" spacing="16.0" styleClass="admin-card"
                              visible="false" managed="false">
                            <children>
                                <VBox spacing="4.0">
                                    <children>
                                        <Label styleClass="seller-page-title" text="Quản lý sản phẩm" />
                                        <Label styleClass="seller-page-subtitle" text="Xem thông tin sản phẩm, ảnh, người bán và trạng thái phiên." wrapText="true" />
                                    </children>
                                </VBox>
                                <HBox alignment="CENTER_LEFT" spacing="14.0">
                                    <children>
                                        <StackPane minHeight="120.0" minWidth="150.0" prefHeight="120.0"
                                                   prefWidth="150.0" styleClass="auction-detail-image-frame">
                                            <children>
                                                <Label fx:id="managedItemImagePlaceholder" styleClass="image-placeholder-text" text="No Image" />
                                                <ImageView fx:id="managedItemImageView" fitHeight="110.0"
                                                           fitWidth="140.0" onMouseClicked="#showManagedItemImagePreview"
                                                           pickOnBounds="true" preserveRatio="true" />
                                            </children>
                                        </StackPane>
                                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="input-label" text="Tên sản phẩm" />
                                                <Label fx:id="managedItemNameValue" styleClass="bidder-item-name"
                                                       text="-" wrapText="true" />
                                                <Label fx:id="managedItemCategoryValue" styleClass="seller-inline-status"
                                                       text="-" wrapText="true" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                                <HBox spacing="18.0">
                                    <children>
                                        <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="input-label" text="Seller" />
                                                <Label fx:id="managedItemSellerValue" styleClass="auction-info-value" text="-" wrapText="true" />
                                                <Label styleClass="input-label" text="Giá hiện tại" />
                                                <Label fx:id="managedItemPriceValue" styleClass="bidder-price-value" text="-" wrapText="true" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="input-label" text="Trạng thái" />
                                                <Label fx:id="managedItemStatusValue" styleClass="seller-inline-status" text="-" wrapText="true" />
                                                <Label styleClass="input-label" text="Lịch đấu giá" />
                                                <Label fx:id="managedItemScheduleValue" styleClass="auction-info-value" text="-" wrapText="true" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                                <VBox spacing="8.0" VBox.vgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="input-label" text="Mô tả" />
                                        <TextArea fx:id="managedItemDescriptionArea" prefRowCount="8"
                                                  styleClass="auction-textarea" wrapText="true"
                                                  VBox.vgrow="ALWAYS" />
                                    </children>
                                </VBox>
                                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                                    <children>
                                        <Button mnemonicParsing="false" onAction="#showManagedItemImagePreview"
                                                styleClass="secondary-button" text="Xem ảnh lớn" />
                                        <Button fx:id="deleteItemButton" mnemonicParsing="false"
                                                onAction="#deleteSelectedItem" styleClass="danger-button"
                                                text="Xóa sản phẩm" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox fx:id="sellerDetailPane" spacing="16.0" styleClass="admin-card"
                              visible="true" managed="true">
                            <children>
                                <VBox spacing="4.0">
                                    <children>
                                        <Label styleClass="seller-page-title" text="Chi tiết seller" />
                                        <Label styleClass="seller-page-subtitle" text="Admin đang đăng nhập:" />
                                        <Label fx:id="adminNameLabel" styleClass="seller-inline-status" text="Admin" />
                                    </children>
                                </VBox>
                                <VBox spacing="10.0">
                                    <children>
                                        <Label styleClass="input-label" text="Họ tên" />
                                        <Label fx:id="sellerNameValue" styleClass="auction-info-value" text="-" wrapText="true" />
                                        <Label styleClass="input-label" text="Tên đăng nhập" />
                                        <Label fx:id="sellerUsernameValue" styleClass="auction-info-value" text="-" wrapText="true" />
                                        <Label styleClass="input-label" text="Email" />
                                        <Label fx:id="sellerEmailValue" styleClass="auction-info-value" text="-" wrapText="true" />
                                        <Label styleClass="input-label" text="Trạng thái" />
                                        <Label fx:id="sellerStatusValue" styleClass="seller-inline-status" text="-" wrapText="true" />
                                    </children>
                                </VBox>
                                <Region VBox.vgrow="ALWAYS" />
                                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                                    <children>
                                        <Button fx:id="approveSellerButton" mnemonicParsing="false"
                                                onAction="#approveSeller" styleClass="primary-button"
                                                text="Duyệt seller" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <!-- CARD 2: Chi tiết Phiên -->
                        <VBox fx:id="auctionDetailPane" spacing="16.0" styleClass="admin-card"
                              visible="false" managed="false">
                            <children>
                                <VBox spacing="4.0">
                                    <children>
                                        <Label styleClass="seller-page-title" text="Chi tiết yêu cầu mở phiên" />
                                        <Label styleClass="seller-page-subtitle"
                                               text="Kiểm tra thời gian dự kiến, người bán và nội dung sản phẩm trước khi phê duyệt."
                                               wrapText="true" />
                                    </children>
                                </VBox>
                                <HBox alignment="CENTER_LEFT" spacing="14.0">
                                    <children>
                                        <StackPane minHeight="72.0" minWidth="72.0" prefHeight="72.0"
                                                   prefWidth="72.0" styleClass="bidder-item-icon-box">
                                            <children>
                                                <ImageView fx:id="itemImageView" fitHeight="72.0"
                                                           fitWidth="72.0" preserveRatio="true" />
                                            </children>
                                        </StackPane>
                                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="input-label" text="Tên sản phẩm" />
                                                <Label fx:id="itemNameValue" styleClass="bidder-item-name"
                                                       text="-" wrapText="true" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                                <HBox spacing="18.0">
                                    <children>
                                        <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="input-label" text="Seller ID" />
                                                <Label fx:id="itemSellerValue" styleClass="auction-info-value" text="-" wrapText="true" />
                                                <Label styleClass="input-label" text="Lịch đấu giá" />
                                                <Label fx:id="itemScheduleValue" styleClass="auction-info-value" text="-" wrapText="true" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="input-label" text="Trạng thái" />
                                                <Label fx:id="itemStatusValue" styleClass="seller-inline-status" text="-" wrapText="true" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                                <VBox spacing="8.0" VBox.vgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="input-label" text="Mô tả sản phẩm" />
                                        <TextArea fx:id="itemDescriptionArea" prefRowCount="10"
                                                  styleClass="auction-textarea" wrapText="true"
                                                  VBox.vgrow="ALWAYS" />
                                    </children>
                                </VBox>
                                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                                    <children>
                                        <Button fx:id="rejectAuctionButton" mnemonicParsing="false"
                                                onAction="#rejectAuction" styleClass="danger-button"
                                                text="Từ chối yêu cầu" />
                                        <Button fx:id="approveAuctionButton" mnemonicParsing="false"
                                                onAction="#approveAuction" styleClass="primary-button"
                                                text="Duyệt và mở phiên" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <!-- CARD 3: Chi tiết Nạp tiền -->
                        <VBox fx:id="depositDetailPane" spacing="16.0" styleClass="admin-card"
                              visible="false" managed="false">
                            <children>
                                <VBox spacing="4.0">
                                    <children>
                                        <Label styleClass="seller-page-title" text="Yêu cầu nạp tiền" />
                                        <Label styleClass="seller-page-subtitle"
                                               text="Bidder gửi yêu cầu nạp tiền, admin duyệt thủ công để cộng vào số dư."
                                               wrapText="true" />
                                    </children>
                                </VBox>
                                <VBox spacing="10.0">
                                    <children>
                                        <Label styleClass="input-label" text="Bidder" />
                                        <Label fx:id="depositBidderValue" styleClass="auction-info-value" text="-" wrapText="true" />
                                        <Label styleClass="input-label" text="Số tiền nạp" />
                                        <Label fx:id="depositAmountValue" styleClass="bidder-price-value" text="-" wrapText="true" />
                                        <Label styleClass="input-label" text="Thời gian gửi" />
                                        <Label fx:id="depositCreatedValue" styleClass="auction-info-value" text="-" wrapText="true" />
                                        <Label styleClass="input-label" text="Trạng thái" />
                                        <Label fx:id="depositStatusValue" styleClass="seller-inline-status" text="-" wrapText="true" />
                                    </children>
                                </VBox>
                                <Region VBox.vgrow="ALWAYS" />
                                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                                    <children>
                                        <Button fx:id="approveDepositButton" mnemonicParsing="false"
                                                onAction="#approveDeposit" styleClass="primary-button"
                                                text="Duyệt nạp tiền" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                    </children>
                </StackPane>

            </children>
        </HBox>
    </center>
</BorderPane>
