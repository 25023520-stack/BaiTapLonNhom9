prefix_rule(
    pattern = ["git"],
    decision = "allow",
    justification = "Allow Git commands in this repository.",
)

prefix_rule(
    pattern = ["python3"],
    decision = "allow",
    justification = "Allow Python 3 commands for local tooling.",
)

prefix_rule(
    pattern = ["mvn", "compile"],
    decision = "allow",
    justification = "Allow Maven compile for this project.",
)

prefix_rule(
    pattern = ["mvn", "test"],
    decision = "allow",
    justification = "Allow Maven test runs for this project.",
)

prefix_rule(
    pattern = ["mvn", "package"],
    decision = "allow",
    justification = "Allow Maven package builds for this project.",
)

prefix_rule(
    pattern = ["mvn", "verify"],
    decision = "allow",
    justification = "Allow Maven verify runs for this project.",
)

prefix_rule(
    pattern = ["mvn", "clean", "compile"],
    decision = "allow",
    justification = "Allow clean Maven compile runs for this project.",
)

prefix_rule(
    pattern = ["mvn", "clean", "test"],
    decision = "allow",
    justification = "Allow clean Maven test runs for this project.",
)

prefix_rule(
    pattern = ["mvn", "clean", "package"],
    decision = "allow",
    justification = "Allow clean Maven package builds for this project.",
)

prefix_rule(
    pattern = ["mvn", "clean", "verify"],
    decision = "allow",
    justification = "Allow clean Maven verify runs for this project.",
)

prefix_rule(
    pattern = ["mvn", "exec:java", "-Dexec.mainClass=com.auction.system.server.ServerMain"],
    decision = "allow",
    justification = "Allow starting the auction server entrypoint.",
)

prefix_rule(
    pattern = ["java", "-version"],
    decision = "allow",
    justification = "Allow checking the installed Java version.",
)

prefix_rule(
    pattern = ["java", "--version"],
    decision = "allow",
    justification = "Allow checking the installed Java version.",
)

prefix_rule(
    pattern = ["netstat", "-tlnp"],
    decision = "allow",
    justification = "Allow checking listening ports.",
)

prefix_rule(
    pattern = ["sudo", "lsof", "-i", ":5050"],
    decision = "allow",
    justification = "Allow inspecting port 5050 listeners.",
)

prefix_rule(
    pattern = ["fuser", "5050/tcp"],
    decision = "allow",
    justification = "Allow checking which process owns port 5050.",
)
